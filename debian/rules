#!/usr/bin/make -f

PATCHRIGHT_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/-[^-]*$$//')

%:
	dh $@ --with python3

override_dh_auto_build:
	pip3 download --no-deps "patchright==$(PATCHRIGHT_VERSION)" -d /tmp/patchright-wheel
	python3 -m zipfile -e /tmp/patchright-wheel/patchright-$(PATCHRIGHT_VERSION)-*.whl /tmp/patchright-src/

override_dh_auto_install:
	install -d debian/python3-patchright/usr/lib/python3/dist-packages/
	cp -r /tmp/patchright-src/patchright debian/python3-patchright/usr/lib/python3/dist-packages/
	cp -r /tmp/patchright-src/patchright-$(PATCHRIGHT_VERSION).dist-info \
	      debian/python3-patchright/usr/lib/python3/dist-packages/ 2>/dev/null || true
	install -d debian/python3-patchright/usr/bin/
	install -m 755 /tmp/patchright-src/patchright/__main__.py \
	               debian/python3-patchright/usr/bin/patchright 2>/dev/null || \
	echo '#!/usr/bin/python3' > debian/python3-patchright/usr/bin/patchright && \
	echo 'from patchright.__main__ import main; main()' >> debian/python3-patchright/usr/bin/patchright && \
	chmod 755 debian/python3-patchright/usr/bin/patchright

override_dh_auto_test:
	# Skip tests - requires browser binaries

override_dh_auto_clean:
	dh_auto_clean
	rm -rf /tmp/patchright-wheel /tmp/patchright-src
